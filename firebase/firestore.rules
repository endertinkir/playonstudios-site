rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email == "endergametest@gmail.com";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isGamePayload() {
      return request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.slug is string
        && request.resource.data.slug.size() > 0
        && request.resource.data.status is string
        && request.resource.data.platforms is list;
    }

    function isMetricPayload() {
      return request.resource.data.gameId is string
        && request.resource.data.gameName is string
        && request.resource.data.platform is string
        && request.resource.data.date is string;
    }

    function protectedGrantFields() {
      return [
        'manualNoAdsGranted',
        'manualNoAdsSource',
        'manualNoAdsUpdatedAt',
        'premiumNoAds',
        'premiumNoAdsSource',
        'premiumNoAdsUpdatedAt',
        'revenueCatPremiumNoAds',
        'revenueCatPremiumNoAdsLastCheckedAt'
      ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) &&
        !request.resource.data.keys().hasAny(protectedGrantFields());
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedGrantFields());
      allow delete: if false;
    }

    match /studioGames/{gameId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isGamePayload();
      allow delete: if isAdmin();
    }

    match /studioDailyMetrics/{entryId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isMetricPayload();
      allow delete: if isAdmin();
    }

    // Generated by Cloud Functions from cumulative users/{uid} ad counters.
    match /userDailyAdMetrics/{entryId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
